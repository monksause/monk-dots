#!/usr/bin/env bash
# rofisearch — Rofi search bar with Zen Browser integration
# Place at ~/.local/bin/rofisearch  and  chmod +x it
#
# ── Features ────────────────────────────────────────────────────────────────
#   • Type anything  → searches in Zen (Google by default)
#   • Type a URL     → opens it directly
#   • Type "-- ..."  → everything after -- opens in a NEW PRIVATE Zen window
#   • Shortcut words → open specific sites instantly (see SHORTCUTS below)
#   • Zen already running → reuses the running instance (wmctrl/xdotool)
#   • Wayland-aware  → uses swaymsg/hyprctl to focus if X tools aren't avail
#
# ── Keybind examples ────────────────────────────────────────────────────────
#   Hyprland:  bind = SUPER, slash, exec, ~/.local/bin/rofisearch
#   i3/sway:   bindsym $mod+slash exec ~/.local/bin/rofisearch
# ────────────────────────────────────────────────────────────────────────────

ROFI_CONFIG="${HOME}/.config/rofi/custom-rofi/config-search.rasi"
SEARCH_ENGINE="https://www.google.com/search?q="
# swap for: "https://search.brave.com/search?q=" or "https://duckduckgo.com/?q="

# ── Shortcut keywords ────────────────────────────────────────────────────────
# Format:  ["keyword"]="url"   (exact match, case-insensitive)
declare -A SHORTCUTS=(
    ["youtube"]="https://youtube.com"
    ["yt"]="https://youtube.com"
    ["claude"]="https://claude.ai"
    ["gmail"]="https://mail.google.com"
    ["mail"]="https://mail.google.com"
    ["gh"]="https://github.com"
    ["github"]="https://github.com"
    ["maps"]="https://maps.google.com"
    ["drive"]="https://drive.google.com"
    ["reddit"]="https://reddit.com"
    ["r/"]="https://reddit.com"           # "r/unixporn" → reddit.com/r/unixporn handled below
    ["twitch"]="https://twitch.tv"
    ["x"]="https://x.com"
    ["twitter"]="https://x.com"
    ["discord"]="https://discord.com/app"
    ["notion"]="https://notion.so"
    ["figma"]="https://figma.com"
    ["vercel"]="https://vercel.com"
    ["dots"]="https://dotfiles.io"
)

# ── Helpers ──────────────────────────────────────────────────────────────────

is_url() {
    # matches http(s)://, ftp://, or bare domain like "github.com/user"
    [[ "$1" =~ ^(https?|ftp):// ]] && return 0
    [[ "$1" =~ ^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}(/.*)?$ ]] && return 0
    return 1
}

zen_is_running() {
    pgrep -x "zen" > /dev/null 2>&1 || \
    pgrep -f "zen-browser" > /dev/null 2>&1 || \
    pgrep -f "zen\.real" > /dev/null 2>&1
}

# Bring Zen window to front (tries multiple focus methods)
focus_zen() {
    # Try wmctrl (X11)
    if command -v wmctrl &>/dev/null; then
        wmctrl -a "Zen Browser" 2>/dev/null && return 0
        wmctrl -a "Mozilla Firefox" 2>/dev/null && return 0   # Zen reports as Firefox
    fi
    # Try xdotool (X11)
    if command -v xdotool &>/dev/null; then
        xdotool search --name "Zen Browser" windowactivate 2>/dev/null && return 0
        xdotool search --class "zen" windowactivate 2>/dev/null && return 0
    fi
    # Try hyprctl (Wayland/Hyprland)
    if command -v hyprctl &>/dev/null; then
        hyprctl dispatch focuswindow "class:zen" 2>/dev/null && return 0
        hyprctl dispatch focuswindow "class:zen-browser" 2>/dev/null && return 0
    fi
    # Try swaymsg (Wayland/sway)
    if command -v swaymsg &>/dev/null; then
        swaymsg '[app_id="zen"] focus' 2>/dev/null && return 0
        swaymsg '[app_id="zen-browser"] focus' 2>/dev/null && return 0
    fi
    return 1
}

open_url() {
    local url="$1"
    local private="$2"   # "true" → private window

    if [[ "$private" == "true" ]]; then
        # Always open a brand-new private window
        zen-browser --private-window "$url" 2>/dev/null \
        || firefox --private-window "$url" 2>/dev/null \
        || xdg-open "$url"
        return
    fi

    if zen_is_running; then
        # Open in existing instance
        zen-browser "$url" 2>/dev/null \
        || firefox "$url" 2>/dev/null \
        || xdg-open "$url"
        sleep 0.15
        focus_zen
    else
        # Launch fresh
        zen-browser "$url" 2>/dev/null \
        || firefox "$url" 2>/dev/null \
        || xdg-open "$url"
    fi
}

build_url() {
    local query="$1"
    local lower
    lower=$(echo "$query" | tr '[:upper:]' '[:lower:]' | xargs)  # trim + lowercase

    # ── Exact shortcut match ─────────────────────────────────────────────────
    if [[ -n "${SHORTCUTS[$lower]}" ]]; then
        echo "${SHORTCUTS[$lower]}"
        return
    fi

    # ── Prefix shortcut: "r/unixporn" → reddit.com/r/unixporn ───────────────
    if [[ "$lower" =~ ^r/(.+) ]]; then
        echo "https://reddit.com/r/${BASH_REMATCH[1]}"
        return
    fi

    # ── "yt <search>" → youtube search ──────────────────────────────────────
    if [[ "$lower" =~ ^yt[[:space:]](.+) ]]; then
        local yt_query
        yt_query=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote_plus(sys.argv[1]))" "${BASH_REMATCH[1]}" 2>/dev/null \
                   || echo "${BASH_REMATCH[1]// /+}")
        echo "https://www.youtube.com/results?search_query=${yt_query}"
        return
    fi

    # ── Direct URL ───────────────────────────────────────────────────────────
    if is_url "$query"; then
        if [[ "$query" =~ ^https?:// ]]; then
            echo "$query"
        else
            echo "https://$query"
        fi
        return
    fi

    # ── Fallback: search engine ──────────────────────────────────────────────
    local encoded
    encoded=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote_plus(sys.argv[1]))" "$query" 2>/dev/null \
              || echo "${query// /+}")
    echo "${SEARCH_ENGINE}${encoded}"
}

# ── Dynamic prompt icon & placeholder ────────────────────────────────────────
get_prompt_for_input() {
    # called once before showing rofi — just set defaults here.
    # The icon updates happen post-submission (we can't hook live input in dmenu).
    echo " "    # 󰖟 globe Nerd Font — looks great next to the bar
}

# ── Main ─────────────────────────────────────────────────────────────────────
pkill -x rofi 2>/dev/null   # close any existing rofi popup

PROMPT_ICON=$(get_prompt_for_input)

RAW=$(rofi \
    -dmenu \
    -p "$PROMPT_ICON" \
    -config "$ROFI_CONFIG" \
    -theme-str "entry { placeholder: \"search · url · shortcut (-- for private)\"; }" \
    < /dev/null)

[[ -z "$RAW" ]] && exit 0

# ── Parse private mode prefix ("-- <query>") ─────────────────────────────────
PRIVATE="false"
QUERY="$RAW"

if [[ "$RAW" =~ ^--[[:space:]]+(.*) ]]; then
    PRIVATE="true"
    QUERY="${BASH_REMATCH[1]}"
    # Show private-mode icon while processing (cosmetic, non-blocking)
fi

[[ -z "$QUERY" ]] && exit 0

# ── Build final URL and open ──────────────────────────────────────────────────
FINAL_URL=$(build_url "$QUERY")
open_url "$FINAL_URL" "$PRIVATE"
